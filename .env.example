# Copy to .env (gitignored) on BOTH the Mac and the Pi, then fill in.
# WiFi is NOT here — it is baked into the SD image at flash time (custom.toml).

# Weather (optional — upstream its-a-plane uses OpenWeatherMap; free key)
OPENWEATHER_API_KEY=

# MBTA (future scene; free key, raises limit 20->1000 req/min)
MBTA_API_KEY=

# Pi connection (Mac-side convenience for SSH; no secret really)
PI_HOST=vestor.local
PI_USER=pi
